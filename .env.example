# Discord Bot
BOT_TOKEN=your_discord_bot_token
GUILD_ID=your_discord_guild_id

# Discord Webhook (optional, for simple PB hook notifications)
WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# PocketBase
PUBLIC_PB_PORT=8090

# OAuth2 Providers (set ID + secret to enable a provider)
